# ============================================
# Configuration .env pour Frontend (Vercel)
# ============================================
# Ces variables doivent être configurées dans Vercel
# Settings → Environment Variables
# ============================================

# URL de l'API backend (avec /api à la fin)
# Pour production: https://djmanjuke.com/api
# Pour développement local: http://localhost:4000/api
VITE_API_URL=https://djmanjuke.com/api

# URL pour WebSocket/Socket.io (sans /api, sans /ws/jukebox)
# Pour production: https://djmanjuke.com
# Pour développement local: http://localhost:4000
VITE_API_WS_URL=https://djmanjuke.com

# URL de base pour les assets (images, audio)
# Pour production: https://djmanjuke.com/api
# Pour développement local: http://localhost:4000
VITE_ASSETS_BASE_URL=https://djmanjuke.com/api

# Clé publique Stripe (publishable key)
# Mode test: pk_test_...
# Mode production: pk_live_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_51PQFkaP9TcVVYrconHrB3HVKsTaCTnoTfptoR6Bc2sFlCXDPJ3Cv0r44TKJAu09in3jxVO9GI5u6LP8wJuyF0y0H00WqpLSzwz

