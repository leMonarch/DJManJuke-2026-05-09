# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION BEGIN
PassengerAppRoot "/home/djmawdrx/public_html/api"
PassengerBaseURI "/api"
PassengerNodejs "/home/djmawdrx/nodevenv/public_html/api/20/bin/node"
PassengerAppType node
PassengerStartupFile src/server.js
# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION END
RewriteEngine On
# IMPORTANT: Les règles WebSocket doivent être AVANT les règles Passenger
# Le backend écoute sur /api/socket.io, donc on doit router vers /api/socket.io
# WebSocket pour /api/socket.io/ (routage direct vers Node.js)
RewriteCond %{HTTP:Upgrade} =websocket [NC]
RewriteCond %{REQUEST_URI} ^/api/socket\.io
RewriteRule ^api/socket\.io(.*)$ ws://127.0.0.1:4000/api/socket.io$1 [P,L]
# WebSocket pour /api/ws/ (namespace /ws/jukebox)
RewriteCond %{HTTP:Upgrade} =websocket [NC]
RewriteCond %{REQUEST_URI} ^/api/ws
RewriteRule ^api/ws(.*)$ ws://127.0.0.1:4000/api/ws$1 [P,L]
# Activer mod_proxy pour WebSockets
<IfModule mod_proxy.c>
  ProxyPreserveHost On
  ProxyRequests Off
  # Proxy pour /api/socket.io
  ProxyPassMatch ^/api/socket\.io ws://127.0.0.1:4000/api/socket.io
  # Proxy pour /api/ws/ (namespace)
  ProxyPassMatch ^/api/ws/ ws://127.0.0.1:4000/api/ws/
</IfModule>
# HTTP (polling) pour /api/socket.io/ (Passenger gère déjà via PassengerBaseURI)
# Les requêtes HTTP vers /api/socket.io sont automatiquement routées par Passenger
# Router /assets/ vers Express (si les assets ne sont pas servis directement par Apache)
# Les assets sont servis par Express via app.use('/media/images', ...) et app.use('/media/audio', ...)
# Avec PassengerBaseURI "/api", les assets sont accessibles via /api/media/...
# Mais Express sert aussi directement /media/... donc on peut router /media/ vers /api/media/
RewriteCond %{REQUEST_URI} ^/media/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^media/(.*)$ /api/media/$1 [L,P]
