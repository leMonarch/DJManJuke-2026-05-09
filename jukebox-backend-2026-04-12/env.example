# Copier vers .env à la racine du backend et adapter les valeurs.

NODE_ENV=development
PORT=4000

# Front Vite en local
CLIENT_URL=http://localhost:5173
# Optionnel : liste séparée par des virgules (sinon origines prod par défaut + CLIENT_URL)
# CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

APP_BASE_URL=http://localhost:5173
SESSION_SECRET=remplacer-par-32-octets-aleatoires
JWT_SECRET=autre-secret-32-octets-aleatoires

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=place_jukebox

# Paiements (optionnel en local)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_PLATFORM_ACCOUNT_ID=
STRIPE_PRO_PRICE_ID=
